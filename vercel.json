{
  "version": 2,
  "builds": [
    {
      "src": "api/*.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/set-webhook",
      "dest": "api/set-webhook.cjs"
    },
    {
      "src": "/api/telegram-webhook",
      "dest": "api/telegram-webhook.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
